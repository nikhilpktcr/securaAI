{
  "name": "secura-ai",
  "displayName": "Secura AI",
  "publisher": "secura",
  "description": "Your local-first AI Security Engineer",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "secura.fixSecret",
        "title": "Secura: Fix hardcoded secret"
      },
      {
        "command": "secura.openDashboard",
        "title": "Secura: Open security dashboard"
      },
      {
        "command": "secura.scanModifiedFiles",
        "title": "Secura: Scan modified files for security issues"
      },
      {
        "command": "secura.openInsightsTerminal",
        "title": "Secura: Open insights terminal"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "vsce package",
    "test": "npm run compile && node --test test/**/*.test.cjs",
    "demo:triage": "node demo/triage-server.js"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
